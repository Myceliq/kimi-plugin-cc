{
  "description": "Kimi plugin session lifecycle hooks",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": [
              "python3",
              "${CLAUDE_PLUGIN_ROOT}/scripts/kimi-companion.py",
              "session-start"
            ],
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": [
              "python3",
              "${CLAUDE_PLUGIN_ROOT}/scripts/kimi-companion.py",
              "session-end"
            ],
            "timeout": 5
          }
        ]
      }
    ]
  }
}
